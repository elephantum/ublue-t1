[Unit]
Description=Best-effort iBridge USB rebind for Touch Bar
Before=display-manager.service
After=systemd-udevd.service
ConditionPathExists=/usr/libexec/mbp-ibridge-rebind.sh

[Service]
Type=oneshot
ExecStart=/usr/libexec/mbp-ibridge-rebind.sh
RemainAfterExit=true

[Install]
WantedBy=multi-user.target
